generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"  
}

model Address {
  id           String  @id @default(uuid())
  house_number String?
  street       String?
  district     String?
  city         String?
  state        String?
  complement   String?

  user_id     String?  @unique
  user        User?    @relation( fields: [user_id], references: [id])

  enterprise_id     String?  @unique
  enterprise        Enterprise?    @relation( fields: [enterprise_id], references: [id])
}

model Enterprise {
  id           String  @id @default(uuid())
  name         String
  cnpj         String @unique
  contact_1    String
  contact_2    String?

  //relations
  users         User[] 

  address      Address?
  //timestamp
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

}

model User {
  //user data
  id           String  @id @unique @default(uuid())
  email        String  @unique
  password     String
  name         String?
  contact_1    String
  contact_2    String?
  address      Address?  
  AccountVerification Boolean @default(false)


  //relations
  enterpriseId String
  enterprise   Enterprise @relation(fields: [enterpriseId], references: [id])
  
  
  //timestamp
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  

}



 model AccountVerifyToken {
  id        String   @id @default(uuid())
  token     String   @unique
  email     String   @unique 
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  email     String   @unique 
  expiresAt DateTime
  createdAt DateTime @default(now())
}



