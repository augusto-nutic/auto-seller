generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"  
}

model Address {
  id           String  @id @default(uuid())
  house_number String?
  street       String?
  district     String?
  city         String?
  state        String?
  complement   String?

 

  enterprises Enterprise?
}

model Enterprise {
  //user data
  id           String  @id @unique @default(uuid())
  email        String  @unique
  password     String
  name         String?
  contact_1    String
  contact_2    String?

  //relations
  AddressId String @unique
  address    Address @relation(fields: [AddressId], references: [id])



  AccountVerification Boolean @default(false)
  cnpj         String  @unique

  //relations
  members Member[]
  administrative_modules AdministrativeModule[]
  
  
  //timestamp
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt


  roles Role[]
}

model AdministrativeModule{
  id        String   @id @default(uuid())
  name      String
  enterpriseId String
  enterprise    Enterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  //relations
  sectors    Sector[]
  @@index([enterpriseId])
}

model Sector{
  id        String   @id @default(uuid())
  name      String

  //relations
  members Member[]
  administrativeModuleId String
  administrativeModule    AdministrativeModule @relation(fields: [administrativeModuleId], references: [id], onDelete: Cascade)
  @@index([administrativeModuleId])
}

model Member {
  id        String   @id @default(uuid())
  name      String
  email     String  
  password  String
  contact_1 String
  contact_2 String?
  
  //relations
  sectors Sector[]
  roles Role[]
  enterpriseId String
  enterprise    Enterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)

  @@index([enterpriseId])
  @@unique([email, enterpriseId])
}

model Role {
  id        String   @id @default(uuid())
  name      String   
  //relations
  enterpriseID String
  enterprise    Enterprise @relation(fields: [enterpriseID], references: [id], onDelete: Cascade)
  permissions Permission[]
  members Member[]

  @@unique([name, enterpriseID])
}

model Permission {
  id    String @id @default(uuid())
  name  String @unique

  roles Role[]
}

model AccountVerifyToken {
  id        String   @id @default(uuid())
  token     String   @unique
  email     String   @unique 
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  email     String   @unique 
  expiresAt DateTime
  createdAt DateTime @default(now())
}


