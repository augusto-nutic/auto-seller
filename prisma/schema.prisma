generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"  
}

model Address {
  id           String  @id @default(uuid())
  house_number String?
  street       String?
  district     String?
  city         String?
  state        String?
  complement   String?


  enterprise_id     String?  @unique
  enterprise        Enterprise?    @relation( fields: [enterprise_id], references: [id])
}


model Enterprise {
  //user data
  id           String  @id @unique @default(uuid())
  email        String  @unique
  password     String
  name         String?
  contact_1    String
  contact_2    String?
  address      Address?  
  AccountVerification Boolean @default(false)
  cnpj         String  @unique

  //relations
  
  administrative_modules Administrative_Module[]
  
  //timestamp
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}


model Administrative_Module{
  id        String   @id @default(uuid())
  name      String
  enterprise_id String
  enterprise    Enterprise @relation(fields: [enterprise_id], references: [id])
}

model AccountVerifyToken {
  id        String   @id @default(uuid())
  token     String   @unique
  email     String   @unique 
  expiresAt DateTime
  createdAt DateTime @default(now())
}
model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  email     String   @unique 
  expiresAt DateTime
  createdAt DateTime @default(now())
}


